      "CreateCategoryResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Create category"
          },
          "data": {
            "type": "integer",
            "format": "int32",
            "example": 1
          },
          "request_id": {
            "type": "string",
            "example": "req-123e4567-e89b-12d3-a456-426614174000"
          }
