  },
  "paths": {
    "/ready": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Readiness probe",
        "description": "Checks database readiness and returns service readiness status.",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is ready.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyResponse"
                }
              }
            }
          },
          "503": {
            "description": "Database not available.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "database not available",
                  "request_id": "req-123e4567-e89b-12d3-a456-426614174000"
                }
              }
            }
          }
        },
        "x-negative-tests": [
          "Database connection unavailable returns 503 with error detail.",
          "Invalid method returns 405 if other HTTP verbs are used."
        ]
      }
    },
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Health check",
        "description": "Returns service health status without authentication.",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        },
        "x-negative-tests": [
          "Not applicable for health endpoint because it does not accept a request body."
        ]
      }
    }
  }
