      "TransactionDetailResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Get transaction by ID"
          },
          "data": {
            "$ref": "#/components/schemas/Transaction"
          },
          "request_id": {
            "type": "string",
            "example": "req-123e4567-e89b-12d3-a456-426614174000"
          }
